<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════
         ENTERPRISE SLATE — DEFAULT (LIGHT) THEME
         ═══════════════════════════════════════ -->

    <!-- Base -->
    <SolidColorBrush x:Key="Clr.Surface"     Color="#F1F3F5"/>
    <SolidColorBrush x:Key="Clr.Panel"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Clr.Separator"   Color="#E2E8F0"/>
    <SolidColorBrush x:Key="Clr.TextPrimary" Color="#0F172A"/>
    <SolidColorBrush x:Key="Clr.TextMuted"   Color="#64748B"/>
    <SolidColorBrush x:Key="Clr.Success"     Color="#2FAE7B"/>
    <SolidColorBrush x:Key="Clr.BackgroudCompomentColor" Color="#FFFFFF"/>

    <!-- Root / chrome -->
    <SolidColorBrush x:Key="Clr.Root.Bg"         Color="#F1F3F5"/>

    <!-- Tab control -->
    <SolidColorBrush x:Key="Clr.TabStrip.Bg"     Color="#F1F3F5"/>
    <SolidColorBrush x:Key="Clr.TabStrip.Border" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="Clr.Tab.Text"        Color="#64748B"/>
    <SolidColorBrush x:Key="Clr.Tab.TextActive"  Color="#1E293B"/>
    <SolidColorBrush x:Key="Clr.Tab.TextHover"   Color="#334155"/>
    <SolidColorBrush x:Key="Clr.Tab.Underline"   Color="#1E3A8A"/>
    <SolidColorBrush x:Key="Clr.Tab.ErrorFg"     Color="#1E293B"/>

    <!-- Status bar -->
    <SolidColorBrush x:Key="Clr.StatusBar.Bg"      Color="#E5E7EB"/>
    <SolidColorBrush x:Key="Clr.StatusBar.Border"  Color="#CBD5E1"/>
    <SolidColorBrush x:Key="Clr.IconBtn.Fg"        Color="#475569"/>
    <SolidColorBrush x:Key="Clr.IconBtn.HoverBg"   Color="#D1D5DB"/>
    <SolidColorBrush x:Key="Clr.IconBtn.HoverFg"   Color="#1E293B"/>
    <SolidColorBrush x:Key="Clr.IconBtn.PressedBg" Color="#B8C0CC"/>
    <SolidColorBrush x:Key="Clr.Conn.Bg"           Color="#F1F3F5"/>
    <SolidColorBrush x:Key="Clr.Conn.Label"        Color="#4B5563"/>

    <!-- Preview Migration — backgrounds -->
    <SolidColorBrush x:Key="BrBgMain"           Color="#F1F3F5"/>
    <SolidColorBrush x:Key="BrBgCard"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BrBgHeader"         Color="#E5E7EB"/>
    <SolidColorBrush x:Key="BrBorder"           Color="#E2E8F0"/>
    <SolidColorBrush x:Key="BrTextPri"          Color="#0F172A"/>
    <SolidColorBrush x:Key="BrTextSec"          Color="#64748B"/>
    <SolidColorBrush x:Key="BrDanger"           Color="#FEE2E2"/>
    <SolidColorBrush x:Key="Clr.Chip.Bg"        Color="#F8FAFC"/>
    <SolidColorBrush x:Key="Clr.Preview.BadgeBg" Color="Transparent"/>
    <SolidColorBrush x:Key="Clr.Preview.BadgeFg" Color="Transparent"/>
    <SolidColorBrush x:Key="Clr.Preview.Title"   Color="Transparent"/>
    <SolidColorBrush x:Key="Clr.Pbar.Track"     Color="#E2E8F0"/>
    <SolidColorBrush x:Key="Clr.Pbar.Fill"      Color="#1E3A8A"/>
    <SolidColorBrush x:Key="Clr.BtnUtil.Bg"     Color="#F8FAFC"/>
    <SolidColorBrush x:Key="Clr.LogTitle.Bg"   Color="#F1F3F5"/>
    <SolidColorBrush x:Key="Clr.Log.Bg"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Clr.Log.Text"      Color="#334155"/>

    <!-- Phase strip accents — uniform slate for Default theme -->
    <SolidColorBrush x:Key="Clr.Strip.Faza1"   Color="#334155"/>
    <SolidColorBrush x:Key="Clr.Strip.Faza2"   Color="#334155"/>
    <SolidColorBrush x:Key="Clr.Strip.Faza3"   Color="#334155"/>
    <SolidColorBrush x:Key="Clr.Strip.Faza45"  Color="#334155"/>
    <SolidColorBrush x:Key="Clr.Strip.Faza6"   Color="#334155"/>
    <SolidColorBrush x:Key="Clr.Strip.Util"    Color="#334155"/>

    <!-- Button action colors -->
    <SolidColorBrush x:Key="Clr.Btn.Faza1"     Color="#1E3A8A"/>
    <SolidColorBrush x:Key="Clr.Btn.Faza2"     Color="#1E3A8A"/>
    <SolidColorBrush x:Key="Clr.Btn.Faza3"     Color="#1E3A8A"/>
    <SolidColorBrush x:Key="Clr.Btn.Export"    Color="#1E3A8A"/>
    <SolidColorBrush x:Key="Clr.Btn.Transfer"  Color="#475569"/>
    <SolidColorBrush x:Key="Clr.Btn.Faza6"     Color="#1E3A8A"/>

    <!-- ═══════════════════════════════════════
         BUTTON STYLES (Light / Enterprise Slate)
         ═══════════════════════════════════════ -->

    <ControlTemplate x:Key="TplFlatBtn" TargetType="Button">
        <Border x:Name="bd"
                Background="{TemplateBinding Background}"
                BorderBrush="{StaticResource Clr.Separator}"
                BorderThickness="0"
                CornerRadius="2" Padding="6,0">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="bd" Property="Opacity" Value="0.65"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="bd" Property="Background" Value="#E2E8F0"/>
                <Setter Property="Foreground" Value="#94A3B8"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Primary: flat, dark navy -->
    <Style x:Key="StyBtnPrimary" TargetType="Button">
        <Setter Property="Height"          Value="28"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template"        Value="{StaticResource TplFlatBtn}"/>
    </Style>

    <!-- Stop: soft red, dark red text, visible border -->
    <Style x:Key="StyBtnStop" TargetType="Button">
        <Setter Property="Height"          Value="24"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Background"      Value="#FEE2E2"/>
        <Setter Property="Foreground"      Value="#991B1B"/>
        <Setter Property="BorderBrush"     Value="#FCA5A5"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Padding"         Value="8,2"/>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background"  Value="#E2E8F0"/>
                <Setter Property="Foreground"  Value="#94A3B8"/>
                <Setter Property="BorderBrush" Value="#CBD5E1"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Utility: light bg, border -->
    <Style x:Key="StyBtnUtil" TargetType="Button">
        <Setter Property="Height"          Value="24"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="Background"      Value="{StaticResource Clr.BtnUtil.Bg}"/>
        <Setter Property="Foreground"      Value="{StaticResource BrTextPri}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Padding"         Value="8,2"/>
    </Style>

    <!-- Destructive: muted dark red -->
    <Style x:Key="StyBtnDestr" TargetType="Button">
        <Setter Property="Height"          Value="24"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="Background"      Value="#FEE2E2"/>
        <Setter Property="Foreground"      Value="#7F1D1D"/>
        <Setter Property="BorderBrush"     Value="#FCA5A5"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Padding"         Value="8,2"/>
    </Style>

    <!-- Labels: 8pt, regular, muted -->
    <Style x:Key="StyLbl" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="8"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{StaticResource BrTextSec}"/>
        <Setter Property="Margin"     Value="0,0,0,2"/>
    </Style>

    <!-- Stat value large: 10pt, SemiBold, dark -->
    <Style x:Key="StyVal" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource BrTextPri}"/>
    </Style>

    <!-- Stat value small: 10pt, SemiBold, dark -->
    <Style x:Key="StyValSm" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource BrTextPri}"/>
    </Style>

    <!-- Progress bar: flat, no radius -->
    <Style x:Key="StyPbar" TargetType="ProgressBar">
        <Setter Property="Height" Value="5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{StaticResource Clr.Pbar.Track}" Height="5">
                        <Grid x:Name="PART_Track">
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{StaticResource Clr.Pbar.Fill}"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════
         GLOBAL STYLES (shared, use theme keys)
         ═══════════════════════════════════════ -->

    <Style x:Key="RunningBadge" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Clr.Success}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="MetricLabelText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Clr.TextMuted}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>

    <Style x:Key="MetricValueText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Clr.TextPrimary}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="MetricUnitRun" TargetType="Run">
        <Setter Property="FontWeight" Value="Normal"/>
    </Style>

    <Style x:Key="MetricColumn" TargetType="StackPanel">
        <Setter Property="Margin" Value="0,0,24,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="VerticalDivider" TargetType="Border">
        <Setter Property="Width" Value="1"/>
        <Setter Property="Margin" Value="0,6,24,6"/>
        <Setter Property="Background" Value="{StaticResource Clr.Separator}"/>
    </Style>

    <Style x:Key="HeaderPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Clr.BackgroudCompomentColor}"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="BorderBrush" Value="{StaticResource Clr.Separator}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
</ResourceDictionary>
