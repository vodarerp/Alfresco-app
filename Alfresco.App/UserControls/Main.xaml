<UserControl x:Class="Alfresco.App.UserControls.Main"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Alfresco.App.UserControls"
             xmlns:workerstate="clr-namespace:Alfresco.App.UserControls.WorkerState"
             xmlns:app="clr-namespace:Alfresco.App"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1400">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- ══ TAB CONTROL TEMPLATE ══ -->
        <ControlTemplate x:Key="TplDarkTabControl" TargetType="TabControl">
            <Grid KeyboardNavigation.TabNavigation="Local">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header strip -->
                <Border Grid.Row="0"
                        Background="#181B26"
                        BorderBrush="#272C3F"
                        BorderThickness="0,0,0,1">
                    <TabPanel x:Name="HeaderPanel"
                              IsItemsHost="True"
                              Background="Transparent"
                              Margin="8,0,0,0"/>
                </Border>

                <!-- Content -->
                <ContentPresenter x:Name="PART_SelectedContentHost"
                                  Grid.Row="1"
                                  ContentSource="SelectedContent"/>
            </Grid>
        </ControlTemplate>

        <!-- ══ TAB ITEM STYLE ══ -->
        <Style x:Key="StyDarkTabItem" TargetType="TabItem">
            <Setter Property="Foreground"      Value="#4A5568"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Margin"          Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                Padding="18,11">
                            <ContentPresenter ContentSource="Header"
                                              VerticalAlignment="Center"
                                              TextElement.FontSize="12"
                                              TextElement.FontWeight="SemiBold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter Property="Foreground"                   Value="#D8E0F0"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected"  Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Foreground" Value="#7A8FAD"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- Root: dark background filling the whole control -->
    <Border Background="#13151C">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ══ TAB CONTROL ══ -->
            <TabControl x:Name="tcMain"
                        Grid.Row="0"
                        SelectedIndex="0"
                        SelectionChanged="TabControl_SelectionChanged"
                        Template="{StaticResource TplDarkTabControl}"
                        Background="Transparent"
                        BorderThickness="0">

                <!-- Tab 0: Preview Migration (default) -->
                <TabItem Style="{StaticResource StyDarkTabItem}"
                         Visibility="{Binding IsPreviewMigrationTabVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Preview Migration" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <local:PreviewMigrationUC/>
                </TabItem>

                <!-- Tab 1: LiveLogger -->
                <TabItem x:Name="LiveLoggerTab"
                         Style="{StaticResource StyDarkTabItem}">
                    <TabItem.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Error badge (shown only when UnreadErrors > 0) -->
                            <Grid Grid.Column="1" Margin="0,-4,0,0" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UnreadErrors}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{Binding UnreadErrors}"
                                           FontSize="9" HorizontalAlignment="Right"
                                           Foreground="#F8FAFC" Panel.ZIndex="1"/>
                                <TextBlock Grid.Row="1" FontFamily="Segoe Fluent Icons" Text="&#xe783;"
                                           Margin="0,-3,-2,0" Foreground="#EF4444"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="16"/>
                            </Grid>

                            <TextBlock Grid.Column="0" Text="Log" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        </Grid>
                    </TabItem.Header>
                    <!-- Content added programmatically in code-behind (App.LogViewer) -->
                </TabItem>

            </TabControl>

            <!-- ══ STATUS BAR ══ -->
            <local:StatusBarUC Grid.Row="1" Height="46"/>

        </Grid>
    </Border>

</UserControl>
