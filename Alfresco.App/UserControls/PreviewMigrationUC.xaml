<UserControl x:Class="Alfresco.App.UserControls.PreviewMigrationUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1400">

    <UserControl.Resources>
        <!-- Stilovi su u GlobalStyles.xaml (Dark) i DefaultTheme.xaml (Light) -->
    </UserControl.Resources>

    <!-- Outer grid: visible UI + collapsed compatibility layer -->
    <Grid>

        <!-- ═══════════════════════════════════════════════════════
             VISIBLE UI
             ═══════════════════════════════════════════════════════ -->
        <Border Background="{StaticResource BrBgMain}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Header strip -->
                    <RowDefinition Height="*"/>      <!-- Phases + Log -->
                    <RowDefinition Height="Auto"/>   <!-- Progress bar -->
                </Grid.RowDefinitions>

                <!-- ──────────────────────────────────────────────
                     ROW 0 — HEADER: Title + Global Stats + Status
                     ────────────────────────────────────────────── -->
                <Border Grid.Row="0"
                        Background="{StaticResource BrBgHeader}"
                        BorderBrush="{StaticResource BrBorder}"
                        BorderThickness="0,0,0,1"
                        Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Title -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontSize="17" FontWeight="Black" Foreground="{StaticResource Clr.Preview.Title}">PREVIEW</TextBlock>
                            <TextBlock FontSize="17" FontWeight="Black" Foreground="{StaticResource Clr.Preview.Title}" Margin="3,0,0,0">MIGRATION</TextBlock>
                            <Border Background="{StaticResource Clr.Preview.BadgeBg}" CornerRadius="3" Padding="5,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="PREVIEW TYPE" FontSize="8" FontWeight="Bold" Foreground="{StaticResource Clr.Preview.BadgeFg}"/>
                            </Border>
                        </StackPanel>

                        <!-- Global stats chips -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">

                            <Border Background="{StaticResource Clr.Chip.Bg}" CornerRadius="5" Padding="12,5" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StyLbl}" Text="UKUPNO"/>
                                    <TextBlock x:Name="TxtTotalCount" Style="{StaticResource StyVal}" Text="0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource Clr.Chip.Bg}" CornerRadius="5" Padding="12,5" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StyLbl}" Text="PI"/>
                                    <TextBlock x:Name="TxtPiCount" Style="{StaticResource StyVal}" Text="0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource Clr.Chip.Bg}" CornerRadius="5" Padding="12,5" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StyLbl}" Text="LE"/>
                                    <TextBlock x:Name="TxtLeCount" Style="{StaticResource StyVal}" Text="0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource Clr.Chip.Bg}" CornerRadius="5" Padding="12,5" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StyLbl}" Text="PENDING"/>
                                    <TextBlock x:Name="TxtPendingCount" Style="{StaticResource StyVal}" Text="0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource Clr.Chip.Bg}" CornerRadius="5" Padding="12,5" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StyLbl}" Text="FOLDER READY"/>
                                    <TextBlock x:Name="TxtFolderReadyCount" Style="{StaticResource StyVal}" Text="0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource Clr.Chip.Bg}" CornerRadius="5" Padding="12,5" Margin="3,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource StyLbl}" Text="ZA MOVE"/>
                                    <TextBlock x:Name="TxtDocReadyCount" Style="{StaticResource StyVal}" Text="0"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <!-- Status -->
                        <Border Grid.Column="2" Background="{StaticResource Clr.Chip.Bg}" CornerRadius="5" Padding="12,5">
                            <StackPanel>
                                <TextBlock Style="{StaticResource StyLbl}" Text="STATUS"/>
                                <TextBlock x:Name="TxtStatus" Text="Spremno"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrTextPri}"
                                           MaxWidth="240" TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>

                    </Grid>
                </Border>

                <!-- ──────────────────────────────────────────────
                     ROW 1 — MAIN CONTENT
                     Left 4*  : Phase cards (3 cols × 2 rows)
                     Right 1* : Log output
                     ────────────────────────────────────────────── -->
                <Grid Grid.Row="1" Margin="10,8,10,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="1*" MinWidth="165"/>
                    </Grid.ColumnDefinitions>

                    <!-- ╔══════════════════════╗
                         ║    PHASE CARDS       ║
                         ╚══════════════════════╝ -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ┌─────────────────────────────────────┐
                             │ FAZA 1 — Ucitavanje                 │
                             └─────────────────────────────────────┘ -->
                        <Border Grid.Row="0" Grid.Column="0"
                                Background="{StaticResource BrBgCard}"
                                BorderBrush="{StaticResource BrBorder}" BorderThickness="1"
                                CornerRadius="4" Padding="12,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="3" CornerRadius="2" Background="{StaticResource Clr.Strip.Faza1}" Margin="0,1,7,1"/>
                                    <StackPanel>
                                        <TextBlock Text="FAZA 1" FontSize="9" FontWeight="Bold" Foreground="{StaticResource BrTextSec}"/>
                                        <TextBlock Text="Ucitavanje dokumenata" FontSize="11"
                                                   FontWeight="SemiBold" Foreground="{StaticResource BrTextPri}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Grid Grid.Row="1" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource StyLbl}" Text="UKUPNO"/>
                                        <TextBlock Style="{StaticResource StyValSm}"
                                                   Text="{Binding Text, ElementName=TxtTotalCount}"
                                                   Foreground="#60A5FA"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Style="{StaticResource StyLbl}" Text="PI"/>
                                        <TextBlock Style="{StaticResource StyValSm}"
                                                   Text="{Binding Text, ElementName=TxtPiCount}"
                                                   Foreground="#22C55E"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource StyLbl}" Text="LE"/>
                                        <TextBlock Style="{StaticResource StyValSm}"
                                                   Text="{Binding Text, ElementName=TxtLeCount}"
                                                   Foreground="#F97316"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Grid.Row="2" Margin="0,0,0,8">
                                    <TextBlock Text="IZVOR FOLDERA"
                                               Style="{StaticResource StyLbl}"
                                               Margin="0,0,0,4"/>
                                    <ComboBox x:Name="CmbFaza1FolderFilter"
                                              Height="24" FontSize="11"
                                              Background="{StaticResource Clr.BtnUtil.Bg}" Foreground="Black"
                                              BorderBrush="{StaticResource BrBorder}"
                                              SelectedIndex="0">
                                        <ComboBoxItem Content="Sve (PI + LE)" Tag=""/>
                                        <ComboBoxItem Content="Samo PI"        Tag="PI"/>
                                        <ComboBoxItem Content="Samo LE"        Tag="LE"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Row="3">
                                    <Button x:Name="BtnStartFaza1"
                                            Content="Start"
                                            Style="{StaticResource StyBtnPrimary}"
                                            Background="{StaticResource Clr.Btn.Faza1}"
                                            Click="BtnStartFaza1_Click"
                                            Margin="0,0,0,4"/>
                                    <Button x:Name="BtnStopFaza1"
                                            Content="Stop"
                                            Style="{StaticResource StyBtnStop}"
                                            Click="BtnStopFaza1_Click"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ┌─────────────────────────────────────┐
                             │ FAZA 2 — Priprema foldera           │
                             └─────────────────────────────────────┘ -->
                        <Border Grid.Row="0" Grid.Column="2"
                                Background="{StaticResource BrBgCard}"
                                BorderBrush="{StaticResource BrBorder}" BorderThickness="1"
                                CornerRadius="4" Padding="12,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="3" CornerRadius="2" Background="{StaticResource Clr.Strip.Faza2}" Margin="0,1,7,1"/>
                                    <StackPanel>
                                        <TextBlock Text="FAZA 2" FontSize="9" FontWeight="Bold" Foreground="{StaticResource BrTextSec}"/>
                                        <TextBlock Text="Priprema foldera" FontSize="11"
                                                   FontWeight="SemiBold" Foreground="{StaticResource BrTextPri}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Grid Grid.Row="1" Margin="0,0,0,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>                                            
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource StyLbl}" Text="PENDING"/>
                                            <TextBlock Style="{StaticResource StyValSm}"                                    Text="{Binding Text, ElementName=TxtPendingCount}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Style="{StaticResource StyLbl}" Text="FOLDER READY"/>
                                            <TextBlock Style="{StaticResource StyValSm}"
               Text="{Binding Text, ElementName=TxtFolderReadyCount}"
               Foreground="#34D399"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource StyLbl}" Text="GREŠAKA"/>
                                            <TextBlock x:Name="TxtFaza2Errors" Style="{StaticResource StyValSm}"
               Text="0" Foreground="#EF4444"/>
                                        </StackPanel>

                                    </Grid>

                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>                                            
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource StyLbl}" Text="OBRAĐENO FOLDERA"/>
                                            <TextBlock x:Name="TxtFaza2FolderProcessed" Style="{StaticResource StyValSm}"
               Text="0" Foreground="#60A5FA"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Style="{StaticResource StyLbl}" Text="ZA KREIRANJE"/>
                                            <TextBlock x:Name="TxtFaza2FolderPending" Style="{StaticResource StyValSm}"
               Text="0" Foreground="#F59E0B"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                </Grid>

                                <StackPanel Grid.Row="3">
                                    <Button x:Name="BtnStartFaza2"
                                            Content="Start"
                                            Style="{StaticResource StyBtnPrimary}"
                                            Background="{StaticResource Clr.Btn.Faza2}"
                                            Click="BtnStartFaza2_Click"
                                            ToolTip="Proverava da li destination folderi postoje u Alfresci, zove ClientAPI za nepostojece"
                                            Margin="0,0,0,4"/>
                                    <Button x:Name="BtnStopFaza2"
                                            Content="Stop"
                                            Style="{StaticResource StyBtnStop}"
                                            Click="BtnStopFaza2_Click"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ┌─────────────────────────────────────┐
                             │ FAZA 3 — Kreiranje foldera          │
                             └─────────────────────────────────────┘ -->
                        <Border Grid.Row="0" Grid.Column="4"
                                Background="{StaticResource BrBgCard}"
                                BorderBrush="{StaticResource BrBorder}" BorderThickness="1"
                                CornerRadius="4" Padding="12,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="3" CornerRadius="2" Background="{StaticResource Clr.Strip.Faza3}" Margin="0,1,7,1"/>
                                    <StackPanel>
                                        <TextBlock Text="FAZA 3" FontSize="9" FontWeight="Bold" Foreground="{StaticResource BrTextSec}"/>
                                        <TextBlock Text="Kreiranje foldera" FontSize="11"
                                                   FontWeight="SemiBold" Foreground="{StaticResource BrTextPri}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Grid Grid.Row="1" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource StyLbl}" Text="UKUPNO"/>
                                        <TextBlock x:Name="TxtFaza3Total" Style="{StaticResource StyValSm}"
                                                   Text="0" Foreground="#C084FC"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Style="{StaticResource StyLbl}" Text="KREIRATI"/>
                                        <TextBlock x:Name="TxtFaza3Pending" Style="{StaticResource StyValSm}" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource StyLbl}" Text="KREIRANO"/>
                                        <TextBlock x:Name="TxtFaza3Created" Style="{StaticResource StyValSm}"
                                                   Text="0" Foreground="#A855F7"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Style="{StaticResource StyLbl}" Text="GREŠAKA"/>
                                        <TextBlock x:Name="TxtFaza3Errors" Style="{StaticResource StyValSm}"
                                                   Text="0" Foreground="#EF4444"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Grid.Row="3">
                                    <Button x:Name="BtnStartFaza3"
                                            Content="Start"
                                            Style="{StaticResource StyBtnPrimary}"
                                            Background="{StaticResource Clr.Btn.Faza3}"
                                            Click="BtnStartFaza3_Click"
                                            ToolTip="Kreira Alfresco foldere za sve FOLDER_PENDING_CREATION zapise"
                                            Margin="0,0,0,4"/>
                                    <Button x:Name="BtnStopFaza3"
                                            Content="Stop"
                                            Style="{StaticResource StyBtnStop}"
                                            Click="BtnStopFaza3_Click"
                                            IsEnabled="False"
                                            Margin="0,0,0,4"/>
                                    <Button x:Name="BtnRollbackFaza3"
                                            Content="Rollback"
                                            Style="{StaticResource StyBtnDestr}"
                                            Click="BtnRollbackFaza3_Click"
                                            Visibility="Collapsed"
                                            ToolTip="SAMO ZA TESTIRANJE: Brise kreirane Alfresco foldere i resetuje status"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ┌─────────────────────────────────────┐
                             │ FAZA 6+7 — Export / Transfer        │
                             └─────────────────────────────────────┘ -->
                        <Border Grid.Row="2" Grid.Column="0"
                                Background="{StaticResource BrBgCard}"
                                BorderBrush="{StaticResource BrBorder}" BorderThickness="1"
                                CornerRadius="4" Padding="12,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                    <Border Width="3" CornerRadius="2" Background="{StaticResource Clr.Strip.Faza45}" Margin="0,1,7,1"/>
                                    <StackPanel>
                                        <TextBlock Text="FAZA 4/5" FontSize="9" FontWeight="Bold" Foreground="{StaticResource BrTextSec}"/>
                                        <TextBlock Text="Export / Transfer" FontSize="11"
                                                   FontWeight="SemiBold" Foreground="{StaticResource BrTextPri}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Filters -->
                                <Grid Grid.Row="1" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Column="0" Text="Dosije:" FontSize="10"
                                               Foreground="{StaticResource BrTextSec}"
                                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <ComboBox x:Name="CmbTransferDossierType" Grid.Column="1" Height="22" FontSize="11">
                                        <ComboBoxItem Content="(sve)" IsSelected="True"/>
                                        <ComboBoxItem Content="PI"/>
                                        <ComboBoxItem Content="LE"/>
                                    </ComboBox>

                                    <TextBlock Grid.Column="3" Text="Target:" FontSize="10"
                                               Foreground="{StaticResource BrTextSec}"
                                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <ComboBox x:Name="CmbTargetDossierType" Grid.Column="4" Height="22" FontSize="11">
                                        <ComboBoxItem Content="(sve)" IsSelected="True" Tag=""/>
                                        <ComboBoxItem Content="PI"  Tag="500"/>
                                        <ComboBoxItem Content="LE"  Tag="400"/>
                                        <ComboBoxItem Content="ACC" Tag="300"/>
                                        <ComboBoxItem Content="DE"  Tag="700"/>
                                    </ComboBox>

                                    <TextBox x:Name="TxtTransferDocumentType" Visibility="Collapsed"
                                             ToolTip="Prazno = svi tipovi dokumenata"/>
                                </Grid>

                                <StackPanel Grid.Row="3">
                                    <Button x:Name="BtnExport"
                                            Content="Export"
                                            Style="{StaticResource StyBtnPrimary}"
                                            Background="{StaticResource Clr.Btn.Export}"
                                            Click="BtnExport_Click"
                                            ToolTip="Eksportuje PreviewDocStaging u .xlsx (2 sheet-a: PI i LE)"
                                            Margin="0,0,0,4"/>
                                    <Button x:Name="BtnStartTransfer"
                                            Content="Transfer"
                                            Style="{StaticResource StyBtnPrimary}"
                                            Background="{StaticResource Clr.Btn.Transfer}"
                                            Click="BtnStartTransfer_Click"
                                            ToolTip="Prenosi zapise iz PreviewDocStaging u DocStaging"
                                            Margin="0,0,0,4"/>
                                    <Button x:Name="BtnStopTransfer"
                                            Content="Stop"
                                            Style="{StaticResource StyBtnStop}"
                                            Click="BtnStopTransfer_Click"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ┌─────────────────────────────────────┐
                             │ FAZA 8 — Start Migration            │
                             └─────────────────────────────────────┘ -->
                        <Border Grid.Row="2" Grid.Column="2"
                                Background="{StaticResource BrBgCard}"
                                BorderBrush="{StaticResource BrBorder}" BorderThickness="1"
                                CornerRadius="4" Padding="12,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="3" CornerRadius="2" Background="{StaticResource Clr.Strip.Faza6}" Margin="0,1,7,1"/>
                                    <StackPanel>
                                        <TextBlock Text="FAZA 6" FontSize="9" FontWeight="Bold" Foreground="{StaticResource BrTextSec}"/>
                                        <TextBlock Text="Start Migration" FontSize="11"
                                                   FontWeight="SemiBold" Foreground="{StaticResource BrTextPri}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Grid Grid.Row="1" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource StyLbl}" Text="ZA MOVE"/>
                                        <TextBlock x:Name="TxtDocReadyCountAction" Style="{StaticResource StyValSm}"
                                                   Text="0" Foreground="#2DD4BF"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Style="{StaticResource StyLbl}" Text="MIGRIRANO"/>
                                        <TextBlock x:Name="TxtFaza8Migrated" Style="{StaticResource StyValSm}"
                                                   Text="0" Foreground="#22C55E"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource StyLbl}" Text="GREŠAKA"/>
                                        <TextBlock x:Name="TxtFaza8Errors" Style="{StaticResource StyValSm}"
                                                   Text="0" Foreground="#EF4444"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Grid.Row="3">
                                    <Button x:Name="BtnStartMigration"
                                            Content="Start"
                                            Style="{StaticResource StyBtnPrimary}"
                                            Background="{StaticResource Clr.Btn.Faza6}"
                                            Click="BtnStartMigration_Click"
                                            ToolTip="Pokrece MoveService — migrira dokumente iz DocStaging u Alfresco"
                                            Margin="0,0,0,4"/>
                                    <Button x:Name="BtnStopMigration"
                                            Content="Stop"
                                            Style="{StaticResource StyBtnStop}"
                                            Click="BtnStopMigration_Click"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ┌─────────────────────────────────────┐
                             │ UTILITIJI                            │
                             └─────────────────────────────────────┘ -->
                        <Border Grid.Row="2" Grid.Column="4" Visibility="Hidden"
                                Background="{StaticResource BrBgCard}"
                                BorderBrush="{StaticResource BrBorder}" BorderThickness="1"
                                CornerRadius="4" Padding="12,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Width="3" CornerRadius="2" Background="{StaticResource Clr.Strip.Util}" Margin="0,1,7,1"/>
                                    <TextBlock Text="UTILITIJI" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource BrTextSec}" VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2">
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BtnRefreshStats" Grid.Column="0"
                                                Content="Statistika"
                                                Style="{StaticResource StyBtnUtil}"
                                                Click="BtnRefreshStats_Click"/>
                                        <Button x:Name="BtnRefreshData" Grid.Column="2"
                                                Content="Podaci"
                                                Style="{StaticResource StyBtnUtil}"
                                                Click="BtnRefreshData_Click"/>
                                    </Grid>
                                    <Button x:Name="BtnResetCheckpoint"
                                            Content="Reset Checkpoint"
                                            Style="{StaticResource StyBtnDestr}"
                                            Margin="0,0,0,4"
                                            Click="BtnResetCheckpoint_Click"
                                            ToolTip="Brise checkpoint - sledece pokretanje krece od pocetka"/>
                                    <Button x:Name="BtnClearStaging"
                                            Content="Clear Staging"
                                            Style="{StaticResource StyBtnDestr}"
                                            Height="24"
                                            Click="BtnClearStaging_Click"
                                            ToolTip="PAZI: Brise sve zapise iz PreviewDocStaging tabele"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </Grid>
                    <!-- END Phase Cards Grid -->

                    <!-- ╔══════════════════════╗
                         ║    LOG OUTPUT        ║
                         ╚══════════════════════╝ -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Terminal title bar -->
                        <Border Grid.Row="0"
                                Background="{StaticResource Clr.LogTitle.Bg}"
                                BorderBrush="{StaticResource BrBorder}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="5,5,0,0"
                                Padding="9,5">
                            <TextBlock Text="LOG OUTPUT" FontSize="9" FontWeight="Bold"
                                       Foreground="{StaticResource BrTextSec}" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Log text area -->
                        <Border Grid.Row="1"
                                Background="{StaticResource Clr.Log.Bg}"
                                BorderBrush="{StaticResource BrBorder}"
                                BorderThickness="1,0,1,1"
                                CornerRadius="0,0,5,5">
                            <TextBox x:Name="TxtLog"
                                     Background="Transparent"
                                     Foreground="{StaticResource Clr.Log.Text}"
                                     FontFamily="Cascadia Code, Consolas, Courier New"
                                     FontSize="10.5"
                                     BorderThickness="0"
                                     Padding="8,6"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </Border>
                    </Grid>

                </Grid>
                <!-- END ROW 1 -->

                <!-- ──────────────────────────────────────────────
                     ROW 2 — PROGRESS BAR (full width)
                     ────────────────────────────────────────────── -->
                <Border Grid.Row="2"
                        Background="{StaticResource BrBgHeader}"
                        BorderBrush="{StaticResource BrBorder}"
                        BorderThickness="0,1,0,0"
                        Padding="14,8">
                    <StackPanel>
                        <TextBlock x:Name="TxtProgressDetail"
                                   Text="Ceka se pokretanje..."
                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                   FontSize="10.5"
                                   Foreground="{StaticResource BrTextSec}"
                                   Margin="0,0,0,5"/>
                        <ProgressBar x:Name="ProgressBar"
                                     Style="{StaticResource StyPbar}"
                                     Minimum="0" Maximum="100" Value="0"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             HIDDEN — Preserved DataGrid + pagination elements
             so code-behind compiles unchanged.
             ═══════════════════════════════════════════════════════ -->
        <Grid Visibility="Collapsed">
            <StackPanel>
                <DataGrid x:Name="DgPreviewDocs"
                          ItemsSource="{Binding PreviewDocs}"
                          AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"     Binding="{Binding Id}"     Width="55"/>
                        <DataGridTextColumn Header="NodeId" Binding="{Binding NodeId}" Width="80"/>
                        <DataGridTextColumn Header="Naziv"  Binding="{Binding Name}"   Width="180"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock x:Name="TxtTotalRecords"    Text="0"/>
                <TextBlock x:Name="TxtDisplayedRecords" Text="0"/>
                <TextBlock x:Name="TxtCurrentPage"     Text="1"/>
                <TextBlock x:Name="TxtTotalPages"      Text="1"/>

                <ComboBox x:Name="CmbPageSize" SelectionChanged="CmbPageSize_SelectionChanged">
                    <ComboBoxItem Content="25" IsSelected="True"/>
                    <ComboBoxItem Content="50"/>
                    <ComboBoxItem Content="100"/>
                    <ComboBoxItem Content="500"/>
                </ComboBox>

                <Button x:Name="BtnFirstPage" Content="|&lt;" Click="BtnFirstPage_Click"/>
                <Button x:Name="BtnPrevPage"  Content="&lt;"  Click="BtnPrevPage_Click"/>
                <Button x:Name="BtnNextPage"  Content="&gt;"  Click="BtnNextPage_Click"/>
                <Button x:Name="BtnLastPage"  Content="&gt;|" Click="BtnLastPage_Click"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
