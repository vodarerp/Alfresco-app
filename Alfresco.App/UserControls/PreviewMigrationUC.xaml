<UserControl x:Class="Alfresco.App.UserControls.PreviewMigrationUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="300"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Preview Migration"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

        <!-- Statistics + Actions -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Statistics — compact single row -->
            <GroupBox Grid.Row="0" Header="Statistika" Margin="0,0,0,6" Padding="6,4">
                <StackPanel Orientation="Horizontal">
                    <Border BorderBrush="#DDD" BorderThickness="0,0,1,0" Padding="8,2">
                        <StackPanel>
                            <TextBlock Text="Ukupno" FontSize="10" Foreground="Gray"/>
                            <TextBlock x:Name="TxtTotalCount" Text="0" FontSize="15" FontWeight="SemiBold" Foreground="DodgerBlue"/>
                        </StackPanel>
                    </Border>
                    <Border BorderBrush="#DDD" BorderThickness="0,0,1,0" Padding="8,2">
                        <StackPanel>
                            <TextBlock Text="PI" FontSize="10" Foreground="Gray"/>
                            <TextBlock x:Name="TxtPiCount" Text="0" FontSize="15" FontWeight="SemiBold" Foreground="ForestGreen"/>
                        </StackPanel>
                    </Border>
                    <Border BorderBrush="#DDD" BorderThickness="0,0,1,0" Padding="8,2">
                        <StackPanel>
                            <TextBlock Text="LE" FontSize="10" Foreground="Gray"/>
                            <TextBlock x:Name="TxtLeCount" Text="0" FontSize="15" FontWeight="SemiBold" Foreground="DarkOrange"/>
                        </StackPanel>
                    </Border>
                    <Border BorderBrush="#DDD" BorderThickness="0,0,1,0" Padding="8,2">
                        <StackPanel>
                            <TextBlock Text="PENDING" FontSize="10" Foreground="Gray"/>
                            <TextBlock x:Name="TxtPendingCount" Text="0" FontSize="15" FontWeight="SemiBold" Foreground="SlateGray"/>
                        </StackPanel>
                    </Border>
                    <Border BorderBrush="#DDD" BorderThickness="0,0,1,0" Padding="8,2">
                        <StackPanel>
                            <TextBlock Text="Folder spreman" FontSize="10" Foreground="Gray"/>
                            <TextBlock x:Name="TxtFolderReadyCount" Text="0" FontSize="15" FontWeight="SemiBold" Foreground="MediumSeaGreen"/>
                        </StackPanel>
                    </Border>
                    <Border BorderBrush="#DDD" BorderThickness="0,0,1,0" Padding="8,2">
                        <StackPanel>
                            <TextBlock Text="Doc READY" FontSize="10" Foreground="Gray"/>
                            <TextBlock x:Name="TxtDocReadyCount" Text="0" FontSize="15" FontWeight="SemiBold" Foreground="Teal"/>
                        </StackPanel>
                    </Border>
                    <Border Padding="8,2">
                        <StackPanel>
                            <TextBlock Text="Status" FontSize="10" Foreground="Gray"/>
                            <TextBlock x:Name="TxtStatus" Text="Spremno" FontSize="12" Foreground="Black"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </GroupBox>

            <!-- Actions — 5 columns, one per phase -->
            <GroupBox Grid.Row="1" Header="Akcije" Padding="8,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Faza 1 -->
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock Text="Faza 1 — Ucitavanje" FontSize="10" Foreground="Gray" Margin="0,0,0,3"/>
                        <Button x:Name="BtnStartFaza1"
                                Content="▶ Pokreni (Faza 1)"
                                Click="BtnStartFaza1_Click"
                                Height="30" Margin="0,0,0,3"
                                Background="#27AE60" Foreground="White" FontWeight="SemiBold"/>
                        <Button x:Name="BtnStopFaza1"
                                Content="⏹ Zaustavi"
                                Click="BtnStopFaza1_Click"
                                Height="26" Margin="0"
                                Background="#E74C3C" Foreground="White"
                                IsEnabled="False"/>
                    </StackPanel>

                    <!-- Faza 2 -->
                    <StackPanel Grid.Column="1" Margin="0,0,6,0">
                        <TextBlock Text="Faza 2 — Priprema foldera" FontSize="10" Foreground="Gray" Margin="0,0,0,3"/>
                        <Button x:Name="BtnStartFaza2"
                                Content="▶ Pokreni (Faza 2)"
                                Click="BtnStartFaza2_Click"
                                Height="30" Margin="0,0,0,3"
                                Background="#2980B9" Foreground="White" FontWeight="SemiBold"
                                ToolTip="Proverava da li destination folderi postoje u Alfresci, zove ClientAPI za nepostojece"/>
                        <Button x:Name="BtnStopFaza2"
                                Content="⏹ Zaustavi"
                                Click="BtnStopFaza2_Click"
                                Height="26" Margin="0"
                                Background="#E74C3C" Foreground="White"
                                IsEnabled="False"/>
                    </StackPanel>

                    <!-- Faza 3 -->
                    <StackPanel Grid.Column="2" Margin="0,0,6,0">
                        <TextBlock Text="Faza 3 — Kreiranje foldera" FontSize="10" Foreground="Gray" Margin="0,0,0,3"/>
                        <Button x:Name="BtnStartFaza3"
                                Content="▶ Pokreni (Faza 3)"
                                Click="BtnStartFaza3_Click"
                                Height="30" Margin="0,0,0,3"
                                Background="#8E44AD" Foreground="White" FontWeight="SemiBold"
                                ToolTip="Kreira Alfresco foldere za sve FOLDER_PENDING_CREATION zapise"/>
                        <Button x:Name="BtnStopFaza3"
                                Content="⏹ Zaustavi"
                                Click="BtnStopFaza3_Click"
                                Height="26" Margin="0,0,0,3"
                                Background="#E74C3C" Foreground="White"
                                IsEnabled="False"/>
                        <Button x:Name="BtnRollbackFaza3"
                                Content="↩ Rollback (TEST)"
                                Click="BtnRollbackFaza3_Click"
                                Height="26" Margin="0"
                                Background="#922B21" Foreground="White"
                                Visibility="Collapsed"
                                ToolTip="SAMO ZA TESTIRANJE: Brise kreirane Alfresco foldere i resetuje status na FOLDER_PENDING_CREATION"/>
                    </StackPanel>

                    <!-- Faza 7 + Faza 6 (Export i Transfer, zajednicki filteri) -->
                    <Grid Grid.Column="3" Margin="0,0,6,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        

                        <StackPanel Grid.Row="0" VerticalAlignment="Bottom">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Dosije:" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,3"/>
                                <ComboBox x:Name="CmbTransferDossierType" Grid.Row="0" Grid.Column="1" Height="22" Margin="0,0,0,3">
                                    <ComboBoxItem Content="(sve)" IsSelected="True"/>
                                    <ComboBoxItem Content="PI"/>
                                    <ComboBoxItem Content="LE"/>
                                </ComboBox>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Target:" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0"/>
                                <ComboBox x:Name="CmbTargetDossierType" Grid.Row="1" Grid.Column="1" Height="22">
                                    <ComboBoxItem Content="(sve)" IsSelected="True" Tag=""/>
                                    <ComboBoxItem Content="PI"  Tag="500"/>
                                    <ComboBoxItem Content="LE"  Tag="400"/>
                                    <ComboBoxItem Content="ACC" Tag="300"/>
                                    <ComboBoxItem Content="DE"  Tag="700"/>
                                </ComboBox>
                                <!-- TipDokumenta filter — privremeno sklonjen sa UI-a -->
                                <TextBox x:Name="TxtTransferDocumentType" Visibility="Collapsed"
                                         ToolTip="Prazno = svi tipovi dokumenata"/>
                            </Grid>
                        </StackPanel>
                        <Grid Grid.Row="1">
                            
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Faza 4 + 5 — Export / Transfer" FontSize="10" Foreground="Gray" Margin="0,0,0,3"/>
                            <Button x:Name="BtnExport"
                                    Content="📊 Eksportuj (Faza 7)"
                                    Click="BtnExport_Click"
                                    Height="30" Margin="0,0,0,3"
                                    Background="#7D3C98" Foreground="White" FontWeight="SemiBold"
                                    ToolTip="Eksportuje PreviewDocStaging u .xlsx (2 sheet-a: PI i LE)"/>
                            <Button x:Name="BtnStartTransfer"
                                    Content="▶ Transfer (Faza 6)"
                                    Click="BtnStartTransfer_Click"
                                    Height="30" Margin="0,0,0,3"
                                    Background="#16A085" Foreground="White" FontWeight="SemiBold"
                                    ToolTip="Prenosi zapise iz PreviewDocStaging u DocStaging"/>
                            <Button x:Name="BtnStopTransfer"
                                    Content="⏹ Zaustavi Transfer"
                                    Click="BtnStopTransfer_Click"
                                    Height="26" Margin="0"
                                    Background="#E74C3C" Foreground="White"
                                    IsEnabled="False"/>
                        </StackPanel>
                        </Grid>
                        <!-- Dugmici: Export pa Transfer -->

                        <!-- Filteri desno od dugmadi -->
                    </Grid>

                    <!-- Faza 8 — Migracija -->
                    <StackPanel Grid.Column="4" Margin="0,0,6,0">
                        <TextBlock Text="Faza 8 — Start Migration" FontSize="10" Foreground="Gray" Margin="0,0,0,3"/>
                        <TextBlock FontSize="10" Foreground="Gray" Margin="0,0,0,3">
                            <Run Text="READY: "/>
                            <Run x:Name="TxtDocReadyCountAction" Text="0" FontWeight="SemiBold" Foreground="Teal"/>
                        </TextBlock>
                        <Button x:Name="BtnStartMigration"
                                Content="▶ Start Migration"
                                Click="BtnStartMigration_Click"
                                Height="30" Margin="0,0,0,3"
                                Background="#1A5276" Foreground="White" FontWeight="SemiBold"
                                IsEnabled="True"
                                ToolTip="Pokrece MoveService — migrira dokumente iz DocStaging u Alfresco"/>
                        <Button x:Name="BtnStopMigration"
                                Content="⏹ Zaustavi"
                                Click="BtnStopMigration_Click"
                                Height="26" Margin="0"
                                Background="#E74C3C" Foreground="White"
                                IsEnabled="False"/>
                    </StackPanel>

                    <!-- Utilitiji -->
                    <StackPanel Grid.Column="5" Margin="0">
                        <TextBlock Text="Utilitiji" FontSize="10" Foreground="Gray" Margin="0,0,0,3"/>
                        <Button x:Name="BtnRefreshStats"
                                Content="↻ Osvezi Statistiku"
                                Click="BtnRefreshStats_Click"
                                Height="24" Margin="0,0,0,2"/>
                        <Button x:Name="BtnRefreshData"
                                Content="↻ Osvezi Podatke"
                                Click="BtnRefreshData_Click"
                                Height="24" Margin="0,0,0,6"/>
                        <Button x:Name="BtnResetCheckpoint"
                                Content="Reset Checkpoint"
                                Click="BtnResetCheckpoint_Click"
                                Height="24" Margin="0,0,0,2"
                                Background="#F39C12" Foreground="White"
                                ToolTip="Brise checkpoint - sledece pokretanje krece od pocetka"/>
                        <Button x:Name="BtnClearStaging"
                                Content="Ocisti PreviewDocStaging"
                                Click="BtnClearStaging_Click"
                                Height="24" Margin="0"
                                Background="#C0392B" Foreground="White"
                                ToolTip="PAZI: Brise sve zapise iz PreviewDocStaging tabele"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Progress Bar -->
        <GroupBox Grid.Row="2" Header="Napredak" Margin="0,0,0,8" Padding="8,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ProgressBar x:Name="ProgressBar" Grid.Row="0"
                             Height="16" Minimum="0" Maximum="100" Value="0"
                             Margin="0,0,0,3"/>
                <TextBlock x:Name="TxtProgressDetail" Grid.Row="1"
                           Text="Ceka se pokretanje..."
                           FontFamily="Consolas" FontSize="11"
                           Foreground="DimGray" TextWrapping="Wrap"/>
            </Grid>
        </GroupBox>

        <!-- Data + Log tabs -->
        <TabControl Grid.Row="3">

            <!-- Preview Data Tab -->
            <TabItem Header="Preview Data">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="DgPreviewDocs" Grid.Row="0"
                              ItemsSource="{Binding PreviewDocs}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserSortColumns="True"
                              SelectionMode="Single"
                              AlternatingRowBackground="AliceBlue"
                              GridLinesVisibility="Horizontal"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              EnableRowVirtualization="True"
                              Margin="0,5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="55"/>
                            <DataGridTextColumn Header="NodeId" Binding="{Binding NodeId}" Width="80"/>
                            <DataGridTextColumn Header="Naziv" Binding="{Binding Name}" Width="180"/>
                            <DataGridTextColumn Header="DocDesc" Binding="{Binding DocDescription}" Width="150"/>
                            <DataGridTextColumn Header="DocType" Binding="{Binding DocumentType}" Width="80"/>
                            <DataGridTextColumn Header="Dosije" Binding="{Binding DossierType}" Width="55"/>
                            <DataGridTextColumn Header="Target" Binding="{Binding TargetDossierType}" Width="55"/>
                            <DataGridTextColumn Header="Dest. Folder" Binding="{Binding DossierDestinationFolderName}" Width="140"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                            <DataGridTextColumn Header="IsActive" Binding="{Binding IsActive}" Width="60"/>
                            <DataGridTextColumn Header="CoreId" Binding="{Binding CoreId}" Width="80"/>
                            <DataGridTextColumn Header="Segment" Binding="{Binding ClientSegment}" Width="60"/>
                            <DataGridTextColumn Header="OldStatus" Binding="{Binding OldAlfrescoStatus}" Width="70"/>
                            <DataGridTextColumn Header="NewStatus" Binding="{Binding NewAlfrescoStatus}" Width="70"/>
                            <DataGridTextColumn Header="Datum Krej." Binding="{Binding OriginalCreatedAt, StringFormat=dd.MM.yyyy}" Width="90"/>
                            <DataGridTextColumn Header="Inserted" Binding="{Binding RecordInserted, StringFormat=dd.MM.yyyy HH:mm}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Pagination -->
                    <Grid Grid.Row="1" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Ukupno: " FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtTotalRecords" Text="0"/>
                            <TextBlock Text="   Prikazano: " Margin="8,0,0,0"/>
                            <TextBlock x:Name="TxtDisplayedRecords" Text="0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Zapisa po strani:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <ComboBox x:Name="CmbPageSize" Width="70" Height="25"
                                      SelectionChanged="CmbPageSize_SelectionChanged">
                                <ComboBoxItem Content="25" IsSelected="True"/>
                                <ComboBoxItem Content="50"/>
                                <ComboBoxItem Content="100"/>
                                <ComboBoxItem Content="500"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="BtnFirstPage" Content="|&lt;" Width="30" Height="25" Margin="2"
                                    Click="BtnFirstPage_Click" ToolTip="Prva strana"/>
                            <Button x:Name="BtnPrevPage" Content="&lt;" Width="30" Height="25" Margin="2"
                                    Click="BtnPrevPage_Click"/>
                            <TextBlock VerticalAlignment="Center" Margin="5,0">
                                <Run Text="Strana "/>
                                <Run x:Name="TxtCurrentPage" Text="1"/>
                                <Run Text=" od "/>
                                <Run x:Name="TxtTotalPages" Text="1"/>
                            </TextBlock>
                            <Button x:Name="BtnNextPage" Content="&gt;" Width="30" Height="25" Margin="2"
                                    Click="BtnNextPage_Click"/>
                            <Button x:Name="BtnLastPage" Content="&gt;|" Width="30" Height="25" Margin="2"
                                    Click="BtnLastPage_Click" ToolTip="Poslednja strana"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Log Output Tab -->
            <TabItem Header="Log Output">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="5">
                    <TextBox x:Name="TxtLog"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             FontFamily="Consolas"
                             FontSize="11"
                             BorderThickness="0"
                             VerticalScrollBarVisibility="Auto"/>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
