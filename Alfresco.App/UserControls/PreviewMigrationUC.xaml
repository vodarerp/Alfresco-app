<UserControl x:Class="Alfresco.App.UserControls.PreviewMigrationUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="350"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Preview Migration - Faza 1: Ucitavanje dokumenata"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Statistics + Actions -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Statistics -->
            <GroupBox Grid.Column="0" Header="Statistika" Margin="0,0,10,0" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Ukupno u Stagingu:" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtTotalCount" Text="0" FontSize="22" Foreground="DodgerBlue"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="PI dokumenti:" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtPiCount" Text="0" FontSize="22" Foreground="ForestGreen"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="5">
                        <TextBlock Text="LE dokumenti:" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtLeCount" Text="0" FontSize="22" Foreground="DarkOrange"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="5">
                        <TextBlock Text="PENDING:" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtPendingCount" Text="0" FontSize="22" Foreground="SlateGray"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Margin="5">
                        <TextBlock Text="Folder spreman:" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtFolderReadyCount" Text="0" FontSize="22" Foreground="MediumSeaGreen"/>
                    </StackPanel>

                    <StackPanel Grid.Column="5" Margin="5">
                        <TextBlock Text="Status:" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtStatus" Text="Spremno" FontSize="14" Foreground="Black" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Actions -->
            <GroupBox Grid.Column="1" Header="Akcije" Padding="10" MinWidth="220">
                <StackPanel>
                    <TextBlock Text="— Faza 1: Ucitavanje —" FontSize="10" Foreground="Gray" Margin="3,0"/>
                    <Button x:Name="BtnStartFaza1"
                            Content="▶ Pokr. Ucitavanje (Faza 1)"
                            Click="BtnStartFaza1_Click"
                            Height="34" Margin="3"
                            Background="#27AE60" Foreground="White" FontWeight="SemiBold"/>

                    <Button x:Name="BtnStopFaza1"
                            Content="⏹ Zaustavi"
                            Click="BtnStopFaza1_Click"
                            Height="34" Margin="3"
                            Background="#E74C3C" Foreground="White" FontWeight="SemiBold"
                            IsEnabled="False"/>

                    <Separator Margin="3"/>
                    <TextBlock Text="— Faza 2: Priprema foldera —" FontSize="10" Foreground="Gray" Margin="3,0"/>
                    <Button x:Name="BtnStartFaza2"
                            Content="▶ Pokr. Pripremu (Faza 2)"
                            Click="BtnStartFaza2_Click"
                            Height="34" Margin="3"
                            Background="#2980B9" Foreground="White" FontWeight="SemiBold"
                            ToolTip="Proverava da li destination folderi postoje u Alfresci, zove ClientAPI za nepostojece"/>

                    <Button x:Name="BtnStopFaza2"
                            Content="⏹ Zaustavi Fazu 2"
                            Click="BtnStopFaza2_Click"
                            Height="28" Margin="3"
                            Background="#E74C3C" Foreground="White"
                            IsEnabled="False"/>

                    <Separator Margin="3"/>
                    <TextBlock Text="— Faza 3: Kreiranje foldera —" FontSize="10" Foreground="Gray" Margin="3,0"/>
                    <Button x:Name="BtnStartFaza3"
                            Content="▶ Pokr. Kreiranje (Faza 3)"
                            Click="BtnStartFaza3_Click"
                            Height="34" Margin="3"
                            Background="#8E44AD" Foreground="White" FontWeight="SemiBold"
                            ToolTip="Kreira Alfresco foldere za sve FOLDER_PENDING_CREATION zapise"/>

                    <Button x:Name="BtnStopFaza3"
                            Content="⏹ Zaustavi Fazu 3"
                            Click="BtnStopFaza3_Click"
                            Height="28" Margin="3"
                            Background="#E74C3C" Foreground="White"
                            IsEnabled="False"/>

                    <Button x:Name="BtnRollbackFaza3"
                            Content="↩ Rollback Faze 3 (TEST)"
                            Click="BtnRollbackFaza3_Click"
                            Height="28" Margin="3"
                            Background="#922B21" Foreground="White"
                            Visibility="Collapsed"
                            ToolTip="SAMO ZA TESTIRANJE: Brise kreirane Alfresco foldere i resetuje status na FOLDER_PENDING_CREATION"/>

                    <Separator Margin="3"/>

                    <Button x:Name="BtnRefreshStats"
                            Content="↻  Osvezi Statistiku"
                            Click="BtnRefreshStats_Click"
                            Height="30" Margin="3"/>

                    <Button x:Name="BtnRefreshData"
                            Content="↻  Osvezi Podatke"
                            Click="BtnRefreshData_Click"
                            Height="30" Margin="3"/>

                    <Separator Margin="3"/>

                    <Button x:Name="BtnResetCheckpoint"
                            Content="Reset Checkpoint"
                            Click="BtnResetCheckpoint_Click"
                            Height="28" Margin="3"
                            Background="#F39C12" Foreground="White"
                            ToolTip="Brise checkpoint - sledece pokretanje krece od pocetka"/>

                    <Button x:Name="BtnClearStaging"
                            Content="Ocisti PreviewDocStaging"
                            Click="BtnClearStaging_Click"
                            Height="28" Margin="3"
                            Background="#C0392B" Foreground="White"
                            ToolTip="PAZI: Brise sve zapise iz PreviewDocStaging tabele"/>

                    <Separator Margin="3"/>
                    <TextBlock Text="— Faza 6: Transfer u DocStaging —" FontSize="10" Foreground="Gray" Margin="3,0"/>

                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Dosije:" VerticalAlignment="Center" Margin="0,0,5,2"/>
                        <ComboBox x:Name="CmbTransferDossierType" Grid.Row="0" Grid.Column="1" Height="24" Margin="0,0,0,2">
                            <ComboBoxItem Content="(sve)" IsSelected="True"/>
                            <ComboBoxItem Content="PI"/>
                            <ComboBoxItem Content="LE"/>
                        </ComboBox>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Tip dok.:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="TxtTransferDocumentType" Grid.Row="1" Grid.Column="1" Height="24"
                                 ToolTip="Prazno = svi tipovi dokumenata"/>
                    </Grid>

                    <Button x:Name="BtnStartTransfer"
                            Content="▶ Pokreni Transfer (Faza 6)"
                            Click="BtnStartTransfer_Click"
                            Height="34" Margin="3"
                            Background="#16A085" Foreground="White" FontWeight="SemiBold"
                            ToolTip="Prenosi zapise iz PreviewDocStaging u DocStaging"/>

                    <Button x:Name="BtnStopTransfer"
                            Content="⏹ Zaustavi Transfer"
                            Click="BtnStopTransfer_Click"
                            Height="28" Margin="3"
                            Background="#E74C3C" Foreground="White"
                            IsEnabled="False"/>

                    <Separator Margin="3"/>
                    <TextBlock Text="— Faza 7: Eksport u Excel —" FontSize="10" Foreground="Gray" Margin="3,0"/>
                    <Button x:Name="BtnExport"
                            Content="📊 Eksportuj u .xlsx"
                            Click="BtnExport_Click"
                            Height="34" Margin="3"
                            Background="#7D3C98" Foreground="White" FontWeight="SemiBold"
                            ToolTip="Eksportuje PreviewDocStaging u .xlsx (2 sheet-a: PI i LE)"/>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- Progress Bar -->
        <GroupBox Grid.Row="2" Header="Napredak" Margin="0,0,0,10" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ProgressBar x:Name="ProgressBar" Grid.Row="0"
                             Height="18" Minimum="0" Maximum="100" Value="0"
                             Margin="0,0,0,5"/>
                <TextBlock x:Name="TxtProgressDetail" Grid.Row="1"
                           Text="Ceka se pokretanje..."
                           FontFamily="Consolas" FontSize="11"
                           Foreground="DimGray" TextWrapping="Wrap"/>
            </Grid>
        </GroupBox>

        <!-- Data + Log tabs -->
        <TabControl Grid.Row="3" Margin="0,0,0,0">

            <!-- Preview Data Tab -->
            <TabItem Header="Preview Data">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="DgPreviewDocs" Grid.Row="1"
                              ItemsSource="{Binding PreviewDocs}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserSortColumns="True"
                              SelectionMode="Single"
                              AlternatingRowBackground="AliceBlue"
                              GridLinesVisibility="Horizontal"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              EnableRowVirtualization="True"
                              Margin="0,5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="55"/>
                            <DataGridTextColumn Header="NodeId" Binding="{Binding NodeId}" Width="80"/>
                            <DataGridTextColumn Header="Naziv" Binding="{Binding Name}" Width="180"/>
                            <DataGridTextColumn Header="DocDesc" Binding="{Binding DocDescription}" Width="150"/>
                            <DataGridTextColumn Header="DocType" Binding="{Binding DocumentType}" Width="80"/>
                            <DataGridTextColumn Header="Dosije" Binding="{Binding DossierType}" Width="55"/>
                            <DataGridTextColumn Header="Target" Binding="{Binding TargetDossierType}" Width="55"/>
                            <DataGridTextColumn Header="Dest. Folder" Binding="{Binding DossierDestinationFolderName}" Width="140"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                            <DataGridTextColumn Header="IsActive" Binding="{Binding IsActive}" Width="60"/>
                            <DataGridTextColumn Header="CoreId" Binding="{Binding CoreId}" Width="80"/>
                            <DataGridTextColumn Header="Segment" Binding="{Binding ClientSegment}" Width="60"/>
                            <DataGridTextColumn Header="OldStatus" Binding="{Binding OldAlfrescoStatus}" Width="70"/>
                            <DataGridTextColumn Header="NewStatus" Binding="{Binding NewAlfrescoStatus}" Width="70"/>
                            <DataGridTextColumn Header="Datum Krej." Binding="{Binding OriginalCreatedAt, StringFormat=dd.MM.yyyy}" Width="90"/>
                            <DataGridTextColumn Header="Inserted" Binding="{Binding RecordInserted, StringFormat=dd.MM.yyyy HH:mm}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Pagination -->
                    <Grid Grid.Row="2" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Ukupno: " FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtTotalRecords" Text="0"/>
                            <TextBlock Text="   Prikazano: " Margin="8,0,0,0"/>
                            <TextBlock x:Name="TxtDisplayedRecords" Text="0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Zapisa po strani:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <ComboBox x:Name="CmbPageSize" Width="70" Height="25"
                                      SelectionChanged="CmbPageSize_SelectionChanged">
                                <ComboBoxItem Content="25" IsSelected="True"/>
                                <ComboBoxItem Content="50"/>
                                <ComboBoxItem Content="100"/>
                                <ComboBoxItem Content="500"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="BtnFirstPage" Content="|&lt;" Width="30" Height="25" Margin="2"
                                    Click="BtnFirstPage_Click" ToolTip="Prva strana"/>
                            <Button x:Name="BtnPrevPage" Content="&lt;" Width="30" Height="25" Margin="2"
                                    Click="BtnPrevPage_Click"/>
                            <TextBlock VerticalAlignment="Center" Margin="5,0">
                                <Run Text="Strana "/>
                                <Run x:Name="TxtCurrentPage" Text="1"/>
                                <Run Text=" od "/>
                                <Run x:Name="TxtTotalPages" Text="1"/>
                            </TextBlock>
                            <Button x:Name="BtnNextPage" Content="&gt;" Width="30" Height="25" Margin="2"
                                    Click="BtnNextPage_Click"/>
                            <Button x:Name="BtnLastPage" Content="&gt;|" Width="30" Height="25" Margin="2"
                                    Click="BtnLastPage_Click" ToolTip="Poslednja strana"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Log Output Tab -->
            <TabItem Header="Log Output">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="5">
                    <TextBox x:Name="TxtLog"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             FontFamily="Consolas"
                             FontSize="11"
                             BorderThickness="0"
                             VerticalScrollBarVisibility="Auto"/>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
