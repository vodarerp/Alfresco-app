<UserControl x:Class="Alfresco.App.UserControls.StatusBarUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Alfresco.App.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="46" d:DesignWidth="1400">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Gear / config button -->
        <Style x:Key="StyIconBtn" TargetType="Button">
            <Setter Property="Width"           Value="30"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Foreground"      Value="{StaticResource Clr.IconBtn.Fg}"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Clr.IconBtn.HoverBg}"/>
                                <Setter Property="Foreground"                 Value="{StaticResource Clr.IconBtn.HoverFg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Clr.IconBtn.PressedBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Reset / secondary action button -->
        <Style x:Key="StyResetBtn" TargetType="Button">
            <Setter Property="Height"          Value="26"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="#B45309"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Border Background="{StaticResource Clr.StatusBar.Bg}"
            BorderBrush="{StaticResource Clr.StatusBar.Border}"
            BorderThickness="0,1,0,0">
        <Grid Margin="10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>   <!-- Config button -->
                <ColumnDefinition Width="*"/>      <!-- Spacer -->
                <ColumnDefinition Width="Auto"/>   <!-- Connection indicators -->
                <ColumnDefinition Width="Auto"/>   <!-- Reset button -->
            </Grid.ColumnDefinitions>

            <!-- ── Config gear button ── -->
            <Button Name="ConfigButton"
                    Grid.Column="0"
                    Content="⚙"
                    Style="{StaticResource StyIconBtn}"
                    VerticalAlignment="Center"
                    Click="ConfigButton_Click"
                    ToolTip="Application Settings"/>

            <!-- ── Connection status indicators ── -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0">

                <!-- Alfresco -->
                <Border Background="{StaticResource Clr.Conn.Bg}" CornerRadius="4"
                        Padding="8,4" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#EF4444"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Connected}" Value="True">
                                            <Setter Property="Fill" Value="#22C55E"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="Alfresco" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource Clr.Conn.Label}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock VerticalAlignment="Center" FontSize="10" FontFamily="Consolas">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text"       Value="Disconnected"/>
                                    <Setter Property="Foreground" Value="#EF4444"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Connected}" Value="True">
                                            <Setter Property="Text"       Value="OK"/>
                                            <Setter Property="Foreground" Value="#22C55E"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- SQL Server -->
                <Border Background="{StaticResource Clr.Conn.Bg}" CornerRadius="4"
                        Padding="8,4" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#EF4444"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DbConnected}" Value="True">
                                            <Setter Property="Fill" Value="#22C55E"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="SQL Server" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource Clr.Conn.Label}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock VerticalAlignment="Center" FontSize="10" FontFamily="Consolas">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text"       Value="Disconnected"/>
                                    <Setter Property="Foreground" Value="#EF4444"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DbConnected}" Value="True">
                                            <Setter Property="Text"       Value="OK"/>
                                            <Setter Property="Foreground" Value="#22C55E"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Client API -->
                <Border Background="{StaticResource Clr.Conn.Bg}" CornerRadius="4"
                        Padding="8,4" Margin="0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#EF4444"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ClientApiConnected}" Value="True">
                                            <Setter Property="Fill" Value="#22C55E"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="Client API" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource Clr.Conn.Label}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock VerticalAlignment="Center" FontSize="10" FontFamily="Consolas">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text"       Value="Disconnected"/>
                                    <Setter Property="Foreground" Value="#EF4444"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ClientApiConnected}" Value="True">
                                            <Setter Property="Text"       Value="OK"/>
                                            <Setter Property="Foreground" Value="#22C55E"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- ── Reset button (shown when any connection fails) ── -->
            <Button Visibility="{Binding ResetButtonVisibilitiCheck}"
                    Grid.Column="3"
                    Content="↻  Retry"
                    Style="{StaticResource StyResetBtn}"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0"
                    Click="SettingsButton_Click"
                    ToolTip="Retry connection checks"/>

        </Grid>
    </Border>

</UserControl>
